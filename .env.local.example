# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Finnhub (free tier: https://finnhub.io)
FINNHUB_API_KEY=your-finnhub-api-key

# Google OAuth (configured in Supabase Dashboard > Auth > Providers > Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cron secret — Vercel sets Authorization: Bearer $CRON_SECRET on scheduled
# requests. /api/refresh-market rejects anything else. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-long-random-string
